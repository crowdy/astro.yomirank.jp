---
import Base from '../layouts/Base.astro';
---

<Base title="運営者情報">
  <div class="page-shell">
    <main class="content">
      <h1>運営者情報</h1>

      <div class="site-description">
        yomirank.jpは、Amazon Kindleのベストセラーランキングを見やすくカテゴリ別に整理し、読者の皆様に最新の書籍情報をお届けするサービスです。読書好きの方々がより良い本に出会えるよう、日々情報を更新しています。
      </div>

      <div class="info-section">
        <h2>サイト情報</h2>
        <table class="info-table">
          <tr><th>サイト名</th><td>yomirank.jp</td></tr>
          <tr><th>URL</th><td><a href="https://yomirank.jp">https://yomirank.jp</a></td></tr>
          <tr><th>サービス内容</th><td>Amazon Kindle ベストセラーランキングの紹介・書籍情報の提供</td></tr>
        </table>
      </div>

      <div class="info-section">
        <h2>運営者情報</h2>
        <table class="info-table">
          <tr><th>運営者</th><td>Munhi Kang</td></tr>
          <tr><th>メールアドレス</th><td><a href="mailto:note.kang527@gmail.com">note.kang527@gmail.com</a></td></tr>
        </table>
      </div>

      <div class="info-section">
        <h2>関連リンク</h2>
        <table class="info-table">
          <tr><th>お問い合わせ</th><td><a href="/contact/">お問い合わせフォーム</a></td></tr>
          <tr><th>プライバシーポリシー</th><td><a href="/privacy-policy/">プライバシーポリシー</a></td></tr>
        </table>
      </div>
    </main>
  </div>
</Base>
