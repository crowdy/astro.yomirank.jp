                width: 100px !important;
            }

            .item-image img {
                height: 150px !important;
            }

            .item-rank {
                position: absolute;
                top: 10px;
                left: 16px;
                z-index: 5;
                width: 32px !important;
                height: 32px !important;
                font-size: 0.75em !important;
                border-radius: 999px;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 2px 6px rgba(0,0,0,0.25);
            }

            .item-rank.top3 {
                width: 34px !important;
                height: 34px !important;
            }

            .item-content {
                padding-left: 4px;
            }
        }
    </style>
</head>
<body>
<header class="header">
    <nav class="nav-container">
        <div class="nav-left">
            <a href="/" style="text-decoration: none; color: inherit;"><span class="logo-text">よみランク</span></a>
            <span class="nav-badge">読書ガイド</span>
            <span class="nav-badge" style="background: #27AE60; color: white;">学習用</span>
        </div>
        <div class="nav-search">
            <form class="search-form" action="/ranking/" method="get">
                <input type="text" name="q" class="search-input" placeholder="書籍を検索..." aria-label="書籍を検索">
                <button type="submit" class="search-btn" aria-label="検索">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </button>
            </form>
        </div>
        <button class="nav-toggle" aria-label="メニューを開閉" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <div class="nav-right">
            <div class="nav-links">
                <a href="/" class="nav-link">時事と本</a>
                <a href="/ranking/" class="nav-link">電子書籍</a>
                <a href="/paper-ranking/" class="nav-link">紙の本</a>
                <a href="/japanese-study/" class="nav-link active">学習用</a>
            </div>
        </div>
    </nav>
</header>

<div class="page-shell">
    <div class="study-notice">
        <h2>📚 日本語学習者向けページ</h2>
        <p>このページでは、漢字の上にふりがな（読み方）が表示されます。<br>
        フォントサイズと行間を大きくして、読みやすくしています。</p>
    </div>

    <main class="content">
        {posts.length === 0 ? (
            <div class="empty-state">
                <p>ふりがな付き記事は現在準備中です。</p>
            </div>
        ) : (
            <ul class="article-list">
                {posts.map((p) => {
                    const preview = rubyPreview(p.data.ruby ?? '');
                    const books = (p.data.books ?? []) as any[];
                    const previewBooks = books.slice(0, 3);
                    return (
                        <li class="article-list-item">
                            <div class="article-meta">
                                <span class="article-theme-badge">{p.data.theme ?? '総合'}</span>
                                <time>📅 {fmt.format(p.data.date)}</time>
                            </div>
                            <h2 class="article-title">
                                <a href={rubyUrl(p)}>{p.data.title}</a>
                            </h2>
                            {preview && (
                                <p class="article-preview">{preview}</p>
                            )}
                            {previewBooks.length > 0 && (
                                <div class="article-book-preview">
                                    {previewBooks.map((book: any) => (
                                        <div class="article-book-thumb">
                                            <img
                                                src={book.image ?? book.imageUrl ?? ''}
                                                alt={book.title ?? ''}
                                                loading="lazy"
                                            />
                                        </div>
                                    ))}
                                    {books.length > 3 && (
                                        <div class="reco-preview-more">+{books.length - 3}</div>
                                    )}
                                </div>
                            )}
                            <div class="read-more-container">
                                <a href={rubyUrl(p)} class="read-more-link">ふりがなで読む →</a>
                            </div>
                        </li>
                    );
                })}
            </ul>
        )}
    </main>
</div>

<footer class="footer">
