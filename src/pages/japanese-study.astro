---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => p.data.ruby && p.data.ruby.trim().length > 0)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 50);

function rubyUrl(p: typeof posts[number]) {
  const d = p.data.date;
  return `/blog/${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}/ruby/${p.data.slug}/`;
}

const fmt = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric',
  timeZone: 'Asia/Tokyo',
});

// Parse {漢字|ふりがな} notation into HTML ruby tags
function parseRuby(text: string): string {
  if (!text) return '';
  return text.replace(/\{([^|]+)\|([^}]+)\}/g, '<ruby>$1<rt>$2</rt></ruby>');
}

// Get a preview of the first paragraph of ruby text (plain text, no ruby tags)
function rubyPreview(rubyText: string): string {
  if (!rubyText) return '';
  const firstPara = rubyText.trim().split(/\n\n/)[0] ?? '';
  // Strip ruby notation to get plain text for excerpt
  const plain = firstPara.replace(/\{([^|]+)\|[^}]+\}/g, '$1');
  return plain.length > 120 ? plain.slice(0, 120) + '…' : plain;
}
