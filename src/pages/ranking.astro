---
import rawData from '../data/bestsellers-latest.json';

// Normalize data: original expects { metadata: { scrapedAtJST }, categories: { [name]: { books: [] } } }
// Our dummy JSON has { scrapedAt, category, books: [] }
// Build normalized shape defensively
const excludeCategories = ['タレント写真集', 'ボーイズラブノベルス'];

let normalizedData: { metadata: { scrapedAtJST: string }, categories: Record<string, { books: any[] }> };

const anyData = rawData as any;

if (anyData.categories && typeof anyData.categories === 'object') {
  // Already correct shape — filter excluded categories
  const filteredCategories: Record<string, { books: any[] }> = {};
  Object.entries(anyData.categories as Record<string, { books: any[] }>).forEach(([name, cat]) => {
    if (!excludeCategories.includes(name)) {
      filteredCategories[name] = cat;
    }
  });
  normalizedData = {
    metadata: { scrapedAtJST: anyData.metadata?.scrapedAtJST ?? anyData.scrapedAt ?? '' },
    categories: filteredCategories,
  };
} else if (Array.isArray(anyData.books)) {
  // Flat shape — group by category field, or use a single "Kindle本" group
  const catMap: Record<string, { books: any[] }> = {};
  (anyData.books as any[]).forEach((book: any) => {
    const catName = book.category || 'Kindle本';
    if (!catMap[catName]) catMap[catName] = { books: [] };
    catMap[catName].books.push({
      rank: book.rank,
      asin: book.asin,
      title: book.title,
      author: book.author,
      category: book.category,
      imageUrl: book.image ?? book.imageUrl ?? '',
      rating: book.rating,
      price: book.price ?? '',
      reviews: book.reviews ?? '',
      link: book.affiliateUrl ?? book.link ?? '',
    });
  });
  // Filter excluded
  const filteredCategories: Record<string, { books: any[] }> = {};
  Object.entries(catMap).forEach(([name, cat]) => {
    if (!excludeCategories.includes(name)) {
      filteredCategories[name] = cat;
    }
  });
  normalizedData = {
    metadata: { scrapedAtJST: anyData.scrapedAt ?? '' },
    categories: filteredCategories,
  };
} else {
  normalizedData = { metadata: { scrapedAtJST: '' }, categories: {} };
}

const jsonPayload = JSON.stringify(normalizedData);
