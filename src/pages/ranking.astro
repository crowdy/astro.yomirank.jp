                width: 32px !important;
                height: 32px !important;
                font-size: 0.85em !important;
                border-radius: 999px;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 2px 6px rgba(0,0,0,0.25);
            }

            .item-rank.top3 {
                width: 34px !important;
                height: 34px !important;
            }

            .item-content {
                padding-left: 4px;
            }
        }

        @media (max-width: 340px) {
            .item-image {
                width: 105px !important;
            }

            .item-image img {
                height: 155px !important;
            }
        }

        .search-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.7);
            z-index: 2000;
            overflow-y: auto;
            padding: var(--spacing-xl);
        }

        .search-overlay.active {
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding-top: calc(var(--header-height) + var(--spacing-xl));
        }

        .search-results-container {
            background: white;
            border-radius: 16px;
            max-width: 700px;
            width: 100%;
            max-height: calc(100vh - var(--header-height) - var(--spacing-xxl) * 2);
            overflow-y: auto;
            box-shadow: var(--shadow-lg);
        }

        .search-results-header {
            padding: var(--spacing-lg);
            border-bottom: 1px solid var(--border-light);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            background: white;
            border-radius: 16px 16px 0 0;
        }

        .search-results-title {
            color: var(--primary-blue);
            font-size: 1.1em;
            font-weight: 600;
        }

        .search-close-btn {
            background: none;
            border: none;
            font-size: 1.5em;
            cursor: pointer;
            color: var(--text-gray);
            padding: 4px 8px;
            border-radius: 8px;
            transition: all 0.2s ease;
        }

        .search-close-btn:hover {
            background: var(--bg-gray-light);
            color: var(--text-dark);
        }

        .search-results-list {
            padding: var(--spacing-md);
        }

        .search-result-item {
            padding: var(--spacing-md);
            border-radius: 12px;
            cursor: pointer;
            transition: background 0.2s ease;
            margin-bottom: var(--spacing-sm);
            border: 1px solid var(--border-light);
        }

        .search-result-item:hover {
            background: var(--bg-gray-light);
            border-color: var(--primary-blue);
        }

        .search-result-title {
            color: var(--primary-blue);
            font-weight: 600;
            margin-bottom: 4px;
        }

        .search-result-category {
            font-size: 0.75em;
            color: var(--text-light);
            margin-bottom: 4px;
        }

        .search-result-author {
            font-size: 0.85em;
            color: var(--text-gray);
        }

        .search-no-results {
            text-align: center;
            padding: var(--spacing-xxl);
            color: var(--text-gray);
        }

        .search-result-item mark {
            background: var(--accent-gold);
            color: var(--primary-dark);
            padding: 0 2px;
            border-radius: 2px;
        }
  </style>
</head>
<body>
  <header class="header">
    <nav class="nav-container">
      <div class="nav-left">
        <a href="/" style="text-decoration: none; color: inherit;"><span class="logo-text">よみランク</span></a>
        <span class="nav-badge">読書ガイド</span>
      </div>
      <div class="nav-search">
        <form class="search-form" id="search-form">
          <input type="text" name="q" class="search-input" placeholder="書籍を検索..." aria-label="書籍を検索" id="search-input">
          <button type="submit" class="search-btn" aria-label="検索">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>
        </form>
      </div>
      <button class="nav-toggle" aria-label="メニューを開閉" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <div class="nav-right">
        <div class="nav-links">
          <a href="/" class="nav-link">時事と本</a>
          <a href="/ranking/" class="nav-link active">電子書籍</a>
          <a href="/paper-ranking/" class="nav-link">紙の本</a>
          <a href="/japanese-study/" class="nav-link">学習用</a>
        </div>
      </div>
    </nav>
  </header>

  <div class="page-shell">
    <div class="main-container">
      <aside class="sidebar">
        <h2>
          <span>カテゴリ</span>
          <span class="sidebar-stats" id="header-stats">...</span>
        </h2>
        <select class="category-dropdown" id="category-dropdown" aria-label="カテゴリを選択">
          <option value="">カテゴリを選択...</option>
        </select>
        <ul class="category-list" id="category-list">
        </ul>
      </aside>

      <main class="content">
        <div class="content-header">
          <h1 id="current-category-title"></h1>
          <div class="meta-info">
            <div id="scrape-time">収集時刻: -</div>
            <div id="item-count">書籍数: -</div>
          </div>
        </div>

        <div id="loading" class="loading"></div>
        <div id="list-container" class="list-container" style="display: none;"></div>
      </main>
    </div>
  </div>

  <div class="search-overlay" id="search-overlay" onclick="if(event.target === this) closeSearchResults()">
    <div class="search-results-container">
      <div class="search-results-header">
        <span class="search-results-title" id="search-results-title">検索結果</span>
        <button class="search-close-btn" onclick="closeSearchResults()">&times;</button>
      </div>
      <div class="search-results-list" id="search-results-list"></div>
    </div>
  </div>

  <footer class="footer">
    <div class="footer-container">
      <div class="affiliate-disclosure">
        当サイトはAmazon.co.jpアソシエイトに参加しています。<br>
        当サイト内のリンクから購入された場合、当サイトは紹介料を得ることがあります。
      </div>
      <div class="footer-social">
        <a href="https://note.com/yomirank_jp" target="_blank" rel="noopener noreferrer" class="social-note">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm4.441 16.892c-2.102.144-2.831-.333-3.631-1.078-1.333-1.262-2.393-1.529-4.141-1.529l-.206.007V9.996l.207.006c1.829 0 3.092-.282 4.141-1.528.8-.746 1.529-1.223 3.631-1.078 1.618.111 2.558.988 2.558 2.681v3.134c0 1.693-.94 2.57-2.559 2.681z"/></svg>
          note
        </a>
        <a href="https://x.com/yomirank" target="_blank" rel="noopener noreferrer" class="social-x">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          X
        </a>
      </div>
      <div class="footer-links">
        <a href="/about/">運営者情報</a>
        <a href="/contact/">お問い合わせ</a>
        <a href="/privacy-policy/">プライバシーポリシー</a>
      </div>
      <p>&copy; 2025 yomirank.jp. Data source: Amazon.co.jp</p>
    </div>
  </footer>

  <script type="application/json" id="ranking-data" set:html={jsonPayload}></script>

  <script is:inline>
    var allBooksData = {};
    var currentCategory = 'Kindle本';
    var bookDescriptions = {};

    var excludeCategories = ['タレント写真集', 'ボーイズラブノベルス'];

    function addAffiliateTag(link) {
      if (!link) return '#';
      return link.includes('?') ? link + '&tag=yomirank-22' : link + '?tag=yomirank-22';
    }

    function initBestsellers() {
      try {
        var el = document.getElementById('ranking-data');
        if (!el) return;
        var data = JSON.parse(el.textContent || '{}');

        if (data.metadata && data.metadata.scrapedAtJST) {
          document.getElementById('scrape-time').textContent =
            '収集時刻: ' + data.metadata.scrapedAtJST;
        }

        allBooksData = {};
        var categories = data.categories || {};
        Object.keys(categories).forEach(function(name) {
          if (!excludeCategories.includes(name)) {
            allBooksData[name] = categories[name];
          }
        });

        var totalBooks = 0;
        Object.values(allBooksData).forEach(function(category) {
          totalBooks += (category.books || []).length;
        });

        document.getElementById('header-stats').textContent =
          totalBooks + '冊 ' + Object.keys(allBooksData).length + 'カテゴリ';

        buildCategoryList();

        document.getElementById('loading').style.display = 'none';
        document.getElementById('list-container').style.display = 'flex';

        var firstCategory = Object.keys(allBooksData)[0] || 'Kindle本';
        selectCategory(firstCategory, false);

      } catch (error) {
        console.error('データ初期化エラー:', error);
        document.getElementById('loading').textContent = 'データの読み込みに失敗しました。';
      }
    }

    function buildCategoryList() {
      var listContainer = document.getElementById('category-list');
      var dropdownContainer = document.getElementById('category-dropdown');
      var categories = Object.keys(allBooksData);

      categories.forEach(function(categoryName) {
        var categoryData = allBooksData[categoryName];
        var count = (categoryData.books || []).length;

        var li = document.createElement('li');
        li.className = 'category-item';

        var label = document.createElement('div');
        label.className = 'category-label';
        label.dataset.category = categoryName;
        label.innerHTML =
          '<span class="category-name">' + categoryName + '</span>' +
          '<span class="category-count">' + count + '</span>';

        label.addEventListener('click', function() { selectCategory(categoryName); });

        li.appendChild(label);
        listContainer.appendChild(li);

        var option = document.createElement('option');
        option.value = categoryName;
        option.textContent = categoryName + ' (' + count + ')';
        dropdownContainer.appendChild(option);
      });

      dropdownContainer.addEventListener('change', function(e) {
        if (e.target.value) {
          selectCategory(e.target.value);
        }
      });
    }

    function selectCategory(category, shouldScroll) {
      if (shouldScroll === undefined) shouldScroll = true;
      currentCategory = category;

      document.querySelectorAll('.category-label').forEach(function(label) {
        label.classList.remove('active');
      });

      var selectedLabel = document.querySelector('[data-category="' + category + '"]');
      if (selectedLabel) {
        selectedLabel.classList.add('active');
      }

      var dropdown = document.getElementById('category-dropdown');
      if (dropdown) {
        dropdown.value = category;
      }

      document.getElementById('current-category-title').textContent = category;

      renderBooks(category);

      if (shouldScroll) {
        document.querySelector('.content').scrollIntoView({ behavior: 'smooth' });
      }
    }

    function renderBooks(category) {
      var container = document.getElementById('list-container');
      var itemCount = document.getElementById('item-count');

      var categoryData = allBooksData[category];
      var books = categoryData ? (categoryData.books || []) : [];

      if (books.length === 0) {
        container.innerHTML = '<p style="text-align: center; color: var(--text-gray);">データがありません。</p>';
        itemCount.textContent = '書籍数: 0';
        return;
      }

      books.sort(function(a, b) { return a.rank - b.rank; });

      itemCount.textContent = '書籍数: ' + books.length;

      container.innerHTML = books.map(function(book) {
        var affiliateLink = addAffiliateTag(book.link || book.affiliateUrl || '');
        var imageHtml = book.imageUrl ? (
          '<div class="item-image">' +
          '<img src="' + book.imageUrl + '" alt="' + (book.title || '') + '" loading="lazy"' +
          ' onerror="this.parentElement.style.display=\'none\'">' +
          '</div>'
        ) : '';
        var authorHtml = book.author ? '<div class="item-author">' + book.author + '</div>' : '';
        var descHtml = (book.asin && bookDescriptions[book.asin]) ?
          '<div class="item-description">' + bookDescriptions[book.asin] + '</div>' : '';
        var ratingHtml = book.rating ? '<span class="meta-rating">' + book.rating + '</span>' : '';
        var priceHtml = book.price ? '<span>価格: ' + book.price + '</span>' : '';
        var reviewsHtml = book.reviews ? '<span>予定ポイント: ' + book.reviews + '</span>' : '';
        var asinHtml = book.asin ? '<span>ASIN: ' + book.asin + '</span>' : '';

        return '<article class="list-item" onclick="window.open(\'' + affiliateLink + '\', \'_blank\')">' +
          '<div class="item-rank ' + (book.rank <= 3 ? 'top3' : '') + '">' + (book.rank || '-') + '</div>' +
          imageHtml +
          '<div class="item-content">' +
          '<span class="item-category-badge">' + (book.category || 'BEST') + '</span>' +
          '<h3 class="item-title">' + (book.title || '(タイトル不明)') + '</h3>' +
          authorHtml +
          descHtml +
          '<div class="item-meta">' + ratingHtml + priceHtml + reviewsHtml + asinHtml + '</div>' +
          '</div>' +
          '</article>';
      }).join('');
    }

    function getCategoryFromURL() {
      var params = new URLSearchParams(window.location.search);
      return params.get('category');
    }

    function getSearchQueryFromURL() {
      var params = new URLSearchParams(window.location.search);
      return params.get('q');
    }

    function handleSearch(event) {
      event.preventDefault();
      var query = document.getElementById('search-input').value.trim();
      if (query.length < 2) {
        alert('2文字以上入力してください');
        return false;
      }
      performSearch(query);
      return false;
    }

    function performSearch(query) {
      var results = [];
      var lowerQuery = query.toLowerCase();

      Object.entries(allBooksData).forEach(function(entry) {
        var categoryName = entry[0];
        var categoryData = entry[1];
        (categoryData.books || []).forEach(function(book) {
          var matchFound = false;

          if (book.title && book.title.toLowerCase().includes(lowerQuery)) {
            matchFound = true;
          }

          if (!matchFound && book.author && book.author.toLowerCase().includes(lowerQuery)) {
            matchFound = true;
          }

          if (matchFound) {
            results.push({
              category: categoryName,
              title: highlightQuery(book.title || '(タイトル不明)', query),
              author: book.author ? highlightQuery(book.author, query) : '',
              link: book.link || book.affiliateUrl || '#',
              imageUrl: book.imageUrl || ''
            });
          }
        });
      });

      showSearchResults(results, query);
    }

    function highlightQuery(text, query) {
      var regex = new RegExp('(' + escapeRegex(query) + ')', 'gi');
      return text.replace(regex, '<mark>$1</mark>');
    }

    function escapeRegex(string) {
      return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    function showSearchResults(results, query) {
      var overlay = document.getElementById('search-overlay');
      var resultsList = document.getElementById('search-results-list');
      var title = document.getElementById('search-results-title');

      title.textContent = '「' + query + '」の検索結果 (' + results.length + '件)';

      if (results.length === 0) {
        resultsList.innerHTML = '<div class="search-no-results">該当する書籍が見つかりませんでした。</div>';
      } else {
        resultsList.innerHTML = results.map(function(result) {
          return '<div class="search-result-item" onclick="window.open(\'' + addAffiliateTag(result.link) + '\', \'_blank\')">' +
            '<div class="search-result-category">' + result.category + '</div>' +
            '<div class="search-result-title">' + result.title + '</div>' +
            (result.author ? '<div class="search-result-author">' + result.author + '</div>' : '') +
            '</div>';
        }).join('');
      }

      overlay.classList.add('active');
    }

    function closeSearchResults() {
      document.getElementById('search-overlay').classList.remove('active');
    }

    document.addEventListener('DOMContentLoaded', function() {
      initBestsellers();

      var categoryFromURL = getCategoryFromURL();
      if (categoryFromURL && allBooksData[categoryFromURL]) {
        selectCategory(categoryFromURL, false);
      }

      var searchQuery = getSearchQueryFromURL();
      if (searchQuery) {
        document.getElementById('search-input').value = searchQuery;
        performSearch(searchQuery);
      }

      var searchForm = document.getElementById('search-form');
      if (searchForm) {
        searchForm.addEventListener('submit', handleSearch);
      }

      var navToggle = document.querySelector('.nav-toggle');
      var navLinks = document.querySelector('.nav-links');

      if (navToggle && navLinks) {
        navToggle.addEventListener('click', function() {
          var isOpen = navToggle.classList.toggle('open');
          navLinks.classList.toggle('open');
          navToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });
      }

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          closeSearchResults();
        }
      });
    });
  </script>
</body>
</html>
