---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import bestsellersRaw from '../data/bestsellers-latest.json';

// Get latest 30 published articles
const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 30);

// Build URL from post (using UTC date consistent with [...slug].astro)
function postUrl(p: typeof allPosts[number]) {
  const d = p.data.date;
  return `/blog/${d.getUTCFullYear()}/${String(d.getUTCMonth() + 1).padStart(2, '0')}/${String(d.getUTCDate()).padStart(2, '0')}/${p.data.slug}/`;
}

// Format date for display: "2026年3月10日(火) 16時01分" using JST
function fmtDate(d: Date) {
  const jstMs = d.getTime() + 9 * 60 * 60 * 1000;
  const j = new Date(jstMs);
  const wdj = ['日', '月', '火', '水', '木', '金', '土'][j.getUTCDay()];
  return `${j.getUTCFullYear()}年${j.getUTCMonth() + 1}月${j.getUTCDate()}日(${wdj}) ${j.getUTCHours()}時${String(j.getUTCMinutes()).padStart(2, '0')}分`;
}

// Build sidebar categories from bestsellers JSON
// Real shape: {categories: {name: {books: [...]}}}
// Dummy shape: {scrapedAt, category, books: [...]}
const excludeCategories = ['タレント写真集', 'ボーイズラブノベルス'];

const data = bestsellersRaw as Record<string, unknown>;
let categories: Array<{ name: string; count: number }> = [];
if (data.categories && typeof data.categories === 'object' && !Array.isArray(data.categories)) {
  // Real shape: categories is an object keyed by category name
  categories = Object.entries(data.categories as Record<string, unknown>)
    .filter(([name]) => !excludeCategories.includes(name))
    .map(([name, catData]) => {
      const count = Array.isArray((catData as Record<string, unknown>)?.books)
        ? ((catData as Record<string, unknown>).books as unknown[]).length
        : 0;
      return { name, count };
    });
} // else: flat dummy data — render empty sidebar gracefully

const totalBooks = categories.reduce((acc, c) => acc + c.count, 0);

// Embed article data for client-side search
const searchData = allPosts.map(p => ({
  title: p.data.title,
  url: postUrl(p),
  theme: p.data.theme ?? '',
  // Plain body paragraphs (split on blank lines)
  content: p.body ? p.body.split(/\n\s*\n/).filter((s: string) => s.trim().length > 0) : [],
}));
---

<Base
  title="yomirank.jp: ブログ記事 | 時事と本のおすすめ"
  description="時事ニュースに関連したおすすめのKindle本をAIがキュレーション。話題のトピックと関連書籍で知識を深めましょう。"
>
  <header slot="nav" class="header">
    <nav class="nav-container">
      <div class="nav-left">
        <a href="/" style="text-decoration: none; color: inherit;">
          <img src="/yomirank_logo.jpg" alt="よみランク" style="height: 40px; display: block;" />
        </a>
        <span class="nav-badge">読書ガイド</span>
      </div>
      <div class="nav-search">
        <form class="search-form" id="search-form" action="/" method="get">
          <input type="text" name="q" class="search-input" id="search-input" placeholder="記事を検索..." aria-label="記事を検索" />
          <button type="submit" class="search-btn" aria-label="検索">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>
        </form>
      </div>
      <button class="nav-toggle" aria-label="メニューを開閉" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-right">
        <div class="nav-links">
          <a href="/" class="nav-link active">時事と本</a>
          <a href="/ranking/" class="nav-link">電子書籍</a>
          <a href="/paper-ranking/" class="nav-link">紙の本</a>
          <a href="/japanese-study/" class="nav-link">学習用</a>
        </div>
      </div>
    </nav>
  </header>
  <div class="page-shell">
    <div class="main-container">
      <aside class="sidebar">
        <h2>
          <span>カテゴリ</span>
          <span class="sidebar-stats" id="header-stats">
            {categories.length > 0 ? `${totalBooks}冊 ${categories.length}カテゴリ` : '...'}
          </span>
        </h2>
        <select class="category-dropdown" id="category-dropdown" aria-label="カテゴリを選択">
          <option value="">カテゴリを選択...</option>
          {categories.map(c => (
            <option value={c.name}>{c.name} ({c.count})</option>
          ))}
        </select>
        <ul class="category-list" id="category-list">
          {categories.map(c => (
            <li class="category-item">
              <div class="category-label" data-category={c.name}>
                <span class="category-name">{c.name}</span>
                <span class="category-count">{c.count}</span>
              </div>
            </li>
          ))}
        </ul>
      </aside>

      <main class="content">
        <article id="blog-article">
          {allPosts.map((p, idx) => {
            const paragraphs = p.body
              ? p.body.split(/\n\s*\n/).filter((s: string) => s.trim().length > 0)
              : [];
            const previewParas = paragraphs.slice(0, 3);
            const hasMore = paragraphs.length > 3;

            return (
              <article
                class="blog-article-item"
                data-index={idx}
                style={idx > 0 ? 'margin-top: var(--spacing-xxl); padding-top: var(--spacing-xxl); border-top: 2px solid var(--border-light);' : ''}
              >
                <div class="blog-header">
                  <h1 class="blog-title">
                    <a href={postUrl(p)} style="color: inherit; text-decoration: none;">{p.data.title}</a>
                  </h1>
                  <div class="blog-meta">
                    <span>📅 {fmtDate(p.data.date)}</span>
                    <span>✏️ 編集部</span>
                    {p.data.theme && <span>🏷️ {p.data.theme}</span>}
                  </div>
                </div>

                <div class="blog-content">
                  {previewParas.map((para: string, pIdx: number) => {
                    let text = para.trim();
                    if (pIdx === 2 && hasMore && text.length > 150) {
                      text = text.slice(0, 150) + '...';
                    }
                    return <p>{text}</p>;
                  })}
                  <div class="read-more-container">
                    <a href={postUrl(p)} class="read-more-link">... もっと読む →</a>
                  </div>
                </div>

                {p.data.news && p.data.news.title && (
                  <div class="news-source" style="margin-top: var(--spacing-xl); padding-top: var(--spacing-md); border-top: 1px solid var(--border-light); font-size: 0.8em; color: var(--text-light);">
                    {p.data.news.url
                      ? <>📰 参照元: <a href={p.data.news.url} target="_blank" rel="noopener noreferrer" style="color: var(--primary-blue); text-decoration: none;">{p.data.news.title}</a></>
                      : <>📰 参照元: {p.data.news.title}</>
                    }
                  </div>
                )}

                {p.data.books && p.data.books.length > 0 && (
                  <>
                    <div class="recommendations-header">
                      <h2>📚 おすすめの本</h2>
                      <div class="recommendations-meta">
                        <div>書籍数: {p.data.books.length}</div>
                      </div>
                    </div>
                    <div class="list-container">
                      {p.data.books.map(b => (
                        <a
                          href={b.affiliateUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="list-item"
                        >
                          <div class={`item-rank${b.rank <= 3 ? ' top3' : ''}`}>{b.rank}</div>
                          <div class="item-image">
                            <img src={b.image} alt={b.title} loading="lazy" onerror="this.parentElement.style.display='none'" />
                          </div>
                          <div class="item-content">
                            {b.category && <span class="item-category-badge">{b.category}</span>}
                            <h3 class="item-title">{b.title}</h3>
                            {b.author && <div class="item-author">{b.author}</div>}
                            {b.rating !== undefined && (
                              <div class="item-meta">
                                <span class="meta-rating">⭐ {b.rating}</span>
                              </div>
                            )}
                            {b.point && <div class="item-point">{b.point}</div>}
                          </div>
                        </a>
                      ))}
                    </div>
                  </>
                )}
              </article>
            );
          })}
        </article>
      </main>
    </div>
  </div>

  <!-- 検索結果オーバーレイ -->
  <div class="search-overlay" id="search-overlay" onclick="if(event.target === this) closeSearchResults()">
    <div class="search-results-container">
      <div class="search-results-header">
        <span class="search-results-title" id="search-results-title">検索結果</span>
        <button class="search-close-btn" onclick="closeSearchResults()">&times;</button>
      </div>
      <div class="search-results-list" id="search-results-list"></div>
    </div>
  </div>

  <!-- Embed search data as JSON -->
  <script type="application/json" id="search-data" set:html={JSON.stringify(searchData)} />

  <script is:inline>
    // Load article data from embedded JSON
    var allArticlesData = JSON.parse(document.getElementById('search-data').textContent || '[]');

    // Category navigation
    document.querySelectorAll('.category-label[data-category]').forEach(function(el) {
      el.addEventListener('click', function() {
        var cat = el.getAttribute('data-category');
        if (cat) {
          window.location.href = '/ranking/?category=' + encodeURIComponent(cat);
        }
      });
    });

    var dropdownEl = document.getElementById('category-dropdown');
    if (dropdownEl) {
      dropdownEl.addEventListener('change', function(e) {
        var val = e.target.value;
        if (val) {
          window.location.href = '/ranking/?category=' + encodeURIComponent(val);
        }
      });
    }

    // Search functions
    function handleSearch(event) {
      event.preventDefault();
      var input = document.getElementById('search-input');
      if (!input) return false;
      var query = input.value.trim();
      if (query.length < 2) {
        alert('2文字以上入力してください');
        return false;
      }
      performSearch(query);
      return false;
    }

    function escapeRegex(s) {
      return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    function highlightQuery(text, q) {
      return text.replace(new RegExp('(' + escapeRegex(q) + ')', 'gi'), '<mark>$1</mark>');
    }

    function performSearch(query) {
      var results = [];
      var lower = query.toLowerCase();

      allArticlesData.forEach(function(article, index) {
        var matchFound = false;
        var excerpt = '';

        // Title search
        if (article.title.toLowerCase().includes(lower)) {
          matchFound = true;
          excerpt = article.title;
        }

        // Content search
        if (!matchFound) {
          for (var i = 0; i < article.content.length; i++) {
            var para = article.content[i];
            if (para.toLowerCase().includes(lower)) {
              matchFound = true;
              var matchIndex = para.toLowerCase().indexOf(lower);
              var start = Math.max(0, matchIndex - 30);
              var end = Math.min(para.length, matchIndex + query.length + 50);
              excerpt = (start > 0 ? '...' : '') + para.substring(start, end) + (end < para.length ? '...' : '');
              break;
            }
          }
        }

        // Theme search
        if (!matchFound && article.theme && article.theme.toLowerCase().includes(lower)) {
          matchFound = true;
          excerpt = 'テーマ: ' + article.theme;
        }

        if (matchFound) {
          results.push({
            index: index,
            title: article.title,
            url: article.url,
            excerpt: highlightQuery(excerpt, query)
          });
        }
      });

      showSearchResults(results, query);
    }

    function showSearchResults(results, query) {
      var overlay = document.getElementById('search-overlay');
      var list = document.getElementById('search-results-list');
      var title = document.getElementById('search-results-title');

      title.textContent = '「' + query + '」の検索結果 (' + results.length + '件)';

      if (results.length === 0) {
        list.innerHTML = '<div class="search-no-results">該当する記事が見つかりませんでした。</div>';
      } else {
        list.innerHTML = results.map(function(r) {
          return '<div class="search-result-item" onclick="scrollToArticle(' + r.index + ')">' +
            '<div class="search-result-title">' + r.title + '</div>' +
            '<div class="search-result-excerpt">' + r.excerpt + '</div>' +
            '</div>';
        }).join('');
      }

      overlay.classList.add('active');
    }

    function closeSearchResults() {
      var overlay = document.getElementById('search-overlay');
      if (overlay) overlay.classList.remove('active');
    }

    function scrollToArticle(index) {
      closeSearchResults();
      var article = document.querySelector('.blog-article-item[data-index="' + index + '"]');
      if (article) {
        article.scrollIntoView({ behavior: 'smooth', block: 'start' });
        article.style.transition = 'background-color 0.3s ease';
        article.style.backgroundColor = 'rgba(255, 215, 0, 0.1)';
        setTimeout(function() {
          article.style.backgroundColor = '';
        }, 2000);
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      var searchForm = document.getElementById('search-form');
      if (searchForm) {
        searchForm.addEventListener('submit', handleSearch);
      }

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          closeSearchResults();
        }
      });

      // If page loaded with ?q=foo (e.g. submitted from another page), run that search
      var params = new URLSearchParams(window.location.search);
      var initialQuery = params.get('q');
      if (initialQuery && initialQuery.trim().length >= 2) {
        var input = document.getElementById('search-input');
        if (input) input.value = initialQuery;
        performSearch(initialQuery.trim());
      }
    });
  </script>

  <style is:global>
    :root {
        --primary-dark: #0F2638;
        --primary-blue: #1C3F5E;
        --primary-light: #2C5F7E;
        --accent-orange: #FF9900;
        --accent-gold: #FFD700;
        --bg-white: #FFFFFF;
        --bg-gray-light: #F5F5F5;
        --bg-gray: #F8F9FA;
        --text-dark: #333333;
        --text-gray: #666666;
        --text-light: #6C757D;
        --border-light: #E9ECEF;

        --spacing-xs: 4px;
        --spacing-sm: 8px;
        --spacing-md: 12px;
        --spacing-lg: 16px;
        --spacing-xl: 24px;
        --spacing-xxl: 32px;

        --shadow-sm: 0 2px 5px rgba(0, 0, 0, 0.06);
        --shadow-md: 0 8px 18px rgba(15, 38, 56, 0.12);
        --shadow-lg: 0 12px 30px rgba(15, 38, 56, 0.22);

        --header-height: 60px;
        --sidebar-width: 320px;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        height: 100%;
    }

    body {
        font-family: "Hiragino Kaku Gothic ProN", "Hiragino Sans", Meiryo, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: clamp(14px, 1.3vw + 10px, 16px);
        line-height: 1.6;
        color: var(--text-dark);
        background: radial-gradient(circle at top, #21466A 0, #0F2638 40%, #050B10 100%);
        min-height: 100vh;
    }

    .header {
        background: rgba(15, 38, 56, 0.95);
        backdrop-filter: blur(12px);
        color: white;
        height: var(--header-height);
        box-shadow: 0 1px 0 rgba(255,255,255,0.04);
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 var(--spacing-lg);
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .logo-text {
        font-size: clamp(1.1rem, 2.4vw, 1.3rem);
        font-weight: 700;
        letter-spacing: 0.03em;
    }

    .nav-badge {
        background: var(--accent-gold);
        color: var(--primary-dark);
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 0.75em;
        font-weight: 700;
    }

    /* 검색 폼 스타일 */
    .nav-search {
        flex: 1;
        max-width: 400px;
        display: flex;
        align-items: center;
    }

    .search-form {
        display: flex;
        align-items: center;
        width: 100%;
        position: relative;
    }

    .search-input {
        width: 100%;
        padding: 8px 40px 8px 14px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.1);
        color: white;
        font-size: 0.85em;
        font-family: inherit;
        transition: all 0.2s ease;
    }

    .search-input::placeholder {
        color: rgba(255, 255, 255, 0.5);
    }

    .search-input:focus {
        outline: none;
        background: rgba(255, 255, 255, 0.15);
        border-color: rgba(255, 255, 255, 0.4);
        box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.1);
    }

    .search-btn {
        position: absolute;
        right: 4px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        padding: 6px 10px;
        cursor: pointer;
        color: rgba(255, 255, 255, 0.7);
        transition: color 0.2s ease;
    }

    .search-btn:hover {
        color: white;
    }

    .search-btn svg {
        width: 18px;
        height: 18px;
        display: block;
    }

    .nav-right {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        flex-shrink: 0;
    }

    .nav-links {
        display: flex;
        gap: var(--spacing-md);
        align-items: center;
    }

    .nav-link {
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        font-size: 0.9em;
        padding: 8px 12px;
        border-radius: 999px;
        transition: all 0.2s ease;
        font-weight: 400;
        white-space: nowrap;
    }

    .nav-link:hover {
        color: white;
    }

    .nav-link.active {
        color: white;
        font-weight: 700;
    }

    .nav-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 6px;
        margin-left: 10px;
        border-radius: 999px;
        transition: background 0.2s ease;
    }

    .nav-toggle:hover {
        background: rgba(255,255,255,0.08);
    }

    .nav-toggle span {
        display: block;
        width: 20px;
        height: 2px;
        background: #ffffff;
        margin: 4px 0;
        transition: all 0.3s ease;
        border-radius: 999px;
    }

    .nav-toggle.open span:nth-child(1) {
        transform: translateY(6px) rotate(45deg);
    }

    .nav-toggle.open span:nth-child(2) {
        opacity: 0;
    }

    .nav-toggle.open span:nth-child(3) {
        transform: translateY(-6px) rotate(-45deg);
    }

    .page-shell {
        max-width: 1200px;
        margin: 0 auto;
        padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-xxl);
    }

    .main-container {
        display: grid;
        grid-template-columns: var(--sidebar-width) minmax(0, 1fr);
        gap: var(--spacing-lg);
    }

    .sidebar,
    .content {
        background: rgba(255,255,255,0.98);
        border-radius: 18px;
        box-shadow: var(--shadow-md);
    }

    .sidebar {
        padding: var(--spacing-lg);
        height: fit-content;
        position: sticky;
        top: calc(var(--header-height) + var(--spacing-lg));
        max-height: calc(100vh - var(--header-height) - var(--spacing-lg) * 2);
        overflow-y: auto;
    }

    .sidebar h2 {
        color: var(--primary-blue);
        margin-bottom: var(--spacing-md);
        font-size: 0.95rem;
        border-bottom: 1px solid var(--border-light);
        padding-bottom: var(--spacing-sm);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
    }

    .sidebar-stats {
        font-size: 0.8em;
        color: var(--text-light);
    }

    .category-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .category-item {
        margin: 0;
    }

    .category-label {
        padding: 8px 10px;
        cursor: pointer;
        border-radius: 12px;
        transition: all 0.18s ease;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85em;
    }

    .category-label:hover {
        background: var(--bg-gray-light);
    }

    .category-label.active {
        background: var(--primary-blue);
        color: white;
        font-weight: 600;
    }

    .category-count {
        font-size: 0.8em;
        opacity: 0.85;
        background: rgba(0,0,0,0.06);
        padding: 2px 10px;
        border-radius: 999px;
    }

    .category-label.active .category-count {
        background: rgba(255,255,255,0.18);
    }

    .category-name {
        flex: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .content {
        padding: var(--spacing-xl);
        min-height: 560px;
    }

    .blog-header {
        border-bottom: 2px solid var(--border-light);
        padding-bottom: var(--spacing-md);
        margin-bottom: var(--spacing-xl);
    }

    .blog-title {
        color: var(--primary-blue);
        font-size: clamp(1.4rem, 3.5vw, 2rem);
        margin-bottom: var(--spacing-sm);
        line-height: 1.4;
        font-weight: 700;
    }

    .blog-meta {
        font-size: 0.85em;
        color: var(--text-light);
        display: flex;
        gap: var(--spacing-md);
        flex-wrap: wrap;
    }

    .blog-content {
        font-size: 1em;
        line-height: 1.9;
        margin-bottom: var(--spacing-xxl);
    }

    .blog-content p {
        margin-bottom: var(--spacing-lg);
    }

    .recommendations-header {
        margin-top: var(--spacing-xl);
        margin-bottom: var(--spacing-lg);
        padding-top: var(--spacing-xl);
        border-top: 2px solid var(--border-light);
    }

    .recommendations-header h2 {
        color: var(--primary-blue);
        font-size: clamp(1.2rem, 3vw, 1.6rem);
        margin-bottom: var(--spacing-sm);
    }

    .recommendations-meta {
        font-size: 0.85em;
        color: var(--text-light);
        display: flex;
        gap: var(--spacing-lg);
        flex-wrap: wrap;
    }

    .list-container {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-md);
    }

    .list-item {
