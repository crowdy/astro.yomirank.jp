---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 30);

function postUrl(p: typeof posts[number]) {
  const d = p.data.date;
  return `/blog/${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}/${p.data.slug}/`;
}
const fmt = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric',
  hour: '2-digit', minute: '2-digit',
  timeZone: 'Asia/Tokyo',
});
---

<Base title="yomirank.jp - 時事ニュースと書籍を結ぶ読書ガイド">
  <div class="page-shell">
    <h1 class="page-title">最新の記事</h1>
    <ul class="post-list">
      {posts.map((p) => (
        <li class="post-list-item">
          <a href={postUrl(p)}>
            <div class="post-meta">
              <span class="post-theme">{p.data.theme}</span>
              <time>{fmt.format(p.data.date)}</time>
            </div>
            <h2 class="post-title">{p.data.title}</h2>
            <p class="post-description">{p.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Base>
