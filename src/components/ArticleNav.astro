---
interface Props {
  prevHref?: string;
  rubyHref?: string;
}
const { prevHref, rubyHref } = Astro.props;
---

{rubyHref && (
  <div class="version-toggle">
    <a href={rubyHref}>📖 ふりがな付きで読む</a>
  </div>
)}

<nav class="article-nav">
  <a href="/" class="back-to-home">← 記事一覧に戻る</a>
  {prevHref && <a href={prevHref} class="prev-article">前の記事 →</a>}
</nav>
